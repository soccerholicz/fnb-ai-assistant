# Copy to .env and fill in. Never commit a real .env (see .gitignore).

# --- API server ---
PORT=8080
NODE_ENV=development
# Comma-separated list of origins allowed to call the API (chat widget hosts, dashboard).
CORS_ORIGINS=http://localhost:5173

# --- LLM (wired in JAV-5: agent core) ---
# Anthropic Claude — native tool-calling + streaming. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (wired in JAV-5 / JAV-6) ---
# Managed Postgres (Neon serverless). Get a connection string at https://neon.tech
DATABASE_URL=

# --- Web app (Vite) ---
# Base URL the web app uses to reach the API. In dev, Vite proxies /api to the server.
VITE_API_BASE_URL=/api
